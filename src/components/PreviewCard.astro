---
interface Props {
  title: string;
  description: string;
  linkText: string;
  href: string;
  imgSrc: string;
}

const { title, description, linkText, href, imgSrc } = Astro.props;

const cleanHref = href.startsWith('/') ? `${import.meta.env.BASE_URL.replace(/\/$/, '')}${href}` : href;
const cleanImgSrc = imgSrc.startsWith('/') ? `${import.meta.env.BASE_URL.replace(/\/$/, '')}${imgSrc}` : imgSrc;
---

<article
  class="group flex h-full flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/5 shadow-[0_12px_40px_rgba(0,0,0,0.2)] backdrop-blur-2xl smooth-transition hover:-translate-y-2 hover:border-team-secondary/50 hover:shadow-[0_20px_50px_rgba(38,158,135,0.15)]"
>
  <!-- Fine-bezeled Image -->
  <div class="overflow-hidden relative h-52 w-full border-b border-white/10">
    <div class="absolute inset-0 bg-gradient-to-t from-team-dark/70 via-transparent to-transparent z-10 pointer-events-none"></div>
    <img
      src={cleanImgSrc}
      alt={title}
      class="h-full w-full object-cover group-hover:scale-105 smooth-transition select-none"
      loading="lazy"
    />
  </div>

  <div class="flex flex-grow flex-col p-6">
    <!-- Block Italic Header -->
    <h3 class="mb-3 text-2xl font-black tracking-tight text-team-light uppercase italic group-hover:text-team-secondary smooth-transition">
      {title}
    </h3>
    
    <!-- Balanced Description -->
    <p class="mb-6 line-clamp-3 text-xs leading-relaxed text-team-light/70 font-medium">
      {description}
    </p>
    
    <!-- Technical Chevron Trigger Link -->
    <div class="mt-auto pt-4 border-t border-white/5">
      <a
        href={cleanHref}
        class="inline-flex items-center gap-1.5 text-[10px] font-black tracking-widest uppercase text-team-secondary group-hover:text-team-light smooth-transition"
      >
        {linkText}
        <svg 
          class="w-3 h-3 text-team-secondary group-hover:text-team-light group-hover:translate-x-1 smooth-transition" 
          fill="none" 
          stroke="currentColor" 
          viewBox="0 0 24 24" 
          stroke-width="3"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</article>
