---
const links = [
  { label: 'Home', href: `${import.meta.env.BASE_URL.replace(/\/$/, '') || '/'}` },
  { label: 'About Us', href: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/about` },
  { label: 'Projects', href: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/projects` },
  { label: 'Sponsors', href: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/sponsors` },
  { label: 'Contact', href: `${import.meta.env.BASE_URL.replace(/\/$/, '') || '/'}#contact` },
];

const robotLinks = [
  { label: 'Robot Hangar', href: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/robots` },
  { label: '2026 Robot', href: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/robots/2026` },
  { label: 'Technical Binder', href: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/robots/technical-binder` },
];

const navLinkClass =
  'relative z-10 px-4 py-2 rounded-full font-bold text-[10px] md:text-xs uppercase tracking-wider text-team-light/75 hover:text-team-light hover:bg-white/10 smooth-transition';

const dropdownContainerClass =
  'absolute top-full left-0 mt-2 hidden min-w-[200px] flex-col rounded-2xl border border-white/10 bg-team-dark/95 p-2.5 shadow-2xl backdrop-blur-2xl group-hover:flex animate-fade-in z-50';

const dropdownLinkClass =
  'text-[10px] md:text-xs font-bold uppercase tracking-wider text-team-light/70 hover:text-team-secondary px-4 py-2.5 rounded-xl hover:bg-white/5 smooth-transition';

const mobileNavLinkClass =
  'mobile-nav-link block rounded-xl px-4 py-3 text-xs font-bold uppercase tracking-wider text-team-light/70 smooth-transition hover:bg-white/10 hover:text-team-light';

const mobileSubNavLinkClass =
  'mobile-nav-link block rounded-xl py-2.5 pl-8 pr-4 text-xs font-bold uppercase tracking-wider text-team-light/60 smooth-transition hover:bg-white/5 hover:text-team-secondary';
---

<!-- Suspended floating wrapper - now wider (max-w-7xl) with transition-all for appearing/disappearing scroll animations -->
<div class="fixed top-4 md:top-6 left-1/2 transform -translate-x-1/2 z-50 w-[95%] md:w-[94%] max-w-7xl pointer-events-none transition-all duration-500 cubic-bezier(0.65, 0, 0.35, 1)">
  <nav
    id="navbar"
    class="pointer-events-auto w-full bg-white/5 backdrop-blur-2xl border border-white/15 rounded-full p-2.5 flex items-center justify-between shadow-[0_12px_40px_rgba(0,0,0,0.3)] smooth-transition"
  >
    <div class="flex items-center pl-4">
      <!-- Removed the glowing dot from here -->
      <a
        href={links[0].href}
        class="text-xs md:text-sm font-black tracking-tight uppercase italic text-team-light hover:text-team-secondary smooth-transition flex items-center"
      >
        WILDBYTE
      </a>
    </div>

    <!-- Desktop Navigation Links -->
    <ul class="hidden items-center gap-1 md:flex pr-2">
      {
        links.slice(0, 2).map((link) => (
          <li>
            <a href={link.href} class={navLinkClass}>
              {link.label}
            </a>
          </li>
        ))
      }

      <li class="group relative">
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/robots`} class={navLinkClass}>
          Robots
        </a>
        <div class={dropdownContainerClass}>
          {
            robotLinks.map((link) => (
              <a href={link.href} class={dropdownLinkClass}>
                {link.label}
              </a>
            ))
          }
        </div>
      </li>

      {
        links.slice(2).map((link) => (
          <li>
            <a href={link.href} class={navLinkClass}>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile Navigation Toggle -->
    <div class="pr-2 md:hidden">
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex items-center justify-center rounded-full p-2 bg-white/5 hover:bg-white/10 text-team-light smooth-transition"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Toggle navigation menu"
      >
        <svg
          id="menu-icon-open"
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
        <svg
          id="menu-icon-close"
          class="hidden h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18 18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Dropdown Menu -->
  <div
    id="mobile-menu"
    class="pointer-events-auto hidden mt-3 w-full bg-team-dark/95 backdrop-blur-3xl border border-white/10 rounded-3xl p-3 shadow-2xl smooth-transition"
  >
    <ul class="flex flex-col gap-1">
      {
        links.slice(0, 2).map((link) => (
          <li>
            <a href={link.href} class={mobileNavLinkClass}>
              {link.label}
            </a>
          </li>
        ))
      }

      <li>
        <span class="block px-4 py-2 text-[10px] font-bold tracking-[0.2em] uppercase text-team-secondary">Robots</span>
      </li>
      {
        robotLinks.map((link) => (
          <li>
            <a href={link.href} class={mobileSubNavLinkClass}>
              {link.label}
            </a>
          </li>
        ))
      }

      <li class="h-px bg-white/5 my-1 mx-2"></li>

      {
        links.slice(2).map((link) => (
          <li>
            <a href={link.href} class={mobileNavLinkClass}>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<script>
  const navbar = document.getElementById('navbar');
  if (!navbar) throw new Error('Navbar element not found');

  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');

  if (!menuToggle || !mobileMenu || !menuIconOpen || !menuIconClose) {
    throw new Error('Mobile menu elements not found');
  }

  let lastScrollY = window.scrollY;
  let menuOpen = false;

  const setMenuOpen = (open: boolean) => {
    menuOpen = open;
    menuToggle.setAttribute('aria-expanded', String(open));
    mobileMenu.classList.toggle('hidden', !open);
    menuIconOpen.classList.toggle('hidden', open);
    menuIconClose.classList.toggle('hidden', !open);
  };

  menuToggle.addEventListener('click', () => {
    setMenuOpen(!menuOpen);
  });

  mobileMenu.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });

  const updateNavbar = () => {
    const currentScrollY = window.scrollY;
    const scrollingDown = currentScrollY > lastScrollY;
    const scrolledPastTop = currentScrollY > 0;

    // We can scale or shift the floating pill on scroll
    if (scrolledPastTop) {
      navbar.classList.add('bg-team-dark/85');
      navbar.classList.remove('bg-white/5');
      navbar.classList.add('shadow-[0_12px_45px_rgba(0,0,0,0.5)]');
    } else {
      navbar.classList.remove('bg-team-dark/85');
      navbar.classList.add('bg-white/5');
      navbar.classList.remove('shadow-[0_12px_45px_rgba(0,0,0,0.5)]');
    }

    // Slide navbar up when scrolling down (with smooth transition on parent container)
    const parentContainer = navbar.parentElement;
    if (parentContainer) {
      if (scrollingDown && currentScrollY > 80) {
        parentContainer.classList.add('-translate-y-32');
        setMenuOpen(false);
      } else {
        parentContainer.classList.remove('-translate-y-32');
      }
    }

    lastScrollY = currentScrollY;
  };

  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();
</script>
