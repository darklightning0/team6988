---
import SectionHeader from './SectionHeader.astro';

const inputClass =
  'w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3.5 text-xs md:text-sm font-medium text-team-light tracking-wide placeholder:text-team-light/35 smooth-transition focus:border-team-secondary/80 focus:bg-white/10 focus:outline-none focus:shadow-[0_0_15px_rgba(38,158,135,0.25)]';
---

<section id="contact" class="mx-auto max-w-5xl px-4 py-24">
  <SectionHeader title="GET IN TOUCH"/>

  <div class="grid gap-12 md:grid-cols-2 md:gap-16 items-start">
    <!-- Left Column Telemetry Details -->
    <div class="space-y-8">
      <p class="text-sm md:text-base leading-relaxed text-team-light/65">
        Interested in partnering with Wildbyte? Reach out about sponsorships,
        mentoring opportunities, or community events. Our response channels are fully open.
      </p>

      <div class="space-y-4">
        <!-- Email Status Box -->
        <div class="flex flex-col gap-2 p-5 rounded-2xl border border-white/5 bg-white/5 backdrop-blur-md smooth-transition hover:border-team-secondary/40 hover:bg-white/10">
          <div class="flex items-center gap-2 text-team-secondary select-none">
            <svg
              class="h-3.5 w-3.5 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
              ></path>
            </svg>
            <span class="text-[9px] font-black tracking-[0.2em] uppercase">COMMUNICATION // EMAIL</span>
          </div>
          <a
            href="mailto:contact@frc6988.com"
            class="block text-base md:text-lg font-black tracking-tight text-team-light hover:text-team-secondary smooth-transition italic"
          >
            contact@frc6988.com
          </a>
        </div>

        <!-- Location Status Box -->
        <div class="flex flex-col gap-2 p-5 rounded-2xl border border-white/5 bg-white/5 backdrop-blur-md smooth-transition hover:border-team-secondary/40 hover:bg-white/10">
          <div class="flex items-center gap-2 text-team-secondary select-none">
            <svg
              class="h-3.5 w-3.5 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
              ></path>
            </svg>
            <span class="text-[9px] font-black tracking-[0.2em] uppercase">HEADQUARTERS // LOCATION</span>
          </div>
          <p class="text-base md:text-lg font-black tracking-tight text-team-light select-none italic">
            Your School / City, State
          </p>
        </div>
      </div>
    </div>

    <!-- Right Column Glass Telemetry Panel -->
    <div
      class="rounded-3xl border border-white/10 bg-white/5 p-6 md:p-8 shadow-[0_12px_40px_rgba(0,0,0,0.25)] backdrop-blur-2xl"
    >
      <form class="space-y-5" action="#" method="post">
        <div>
          <label for="name" class="mb-2 block text-[9px] font-black tracking-widest text-team-light/65 uppercase select-none">
            Sender Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class={inputClass}
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="mb-2 block text-[9px] font-black tracking-widest text-team-light/65 uppercase select-none">
            Response Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class={inputClass}
            placeholder="you@example.com"
          />
        </div>

        <div>
          <label
            for="message"
            class="mb-2 block text-[9px] font-black tracking-widest text-team-light/65 uppercase select-none"
          >
            Telemetry Message
          </label>
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            class={`${inputClass} resize-y`}
            placeholder="How can we help?"></textarea>
        </div>

        <button
          type="submit"
          class="w-full rounded-full border border-white/15 bg-team-secondary px-8 py-3.5 text-[10px] font-black tracking-widest uppercase text-team-light shadow-xl smooth-transition hover:bg-team-secondary/80 hover:scale-105 hover:border-white/30 hover:shadow-[0_0_20px_rgba(38,158,135,0.4)] cursor-pointer text-center sm:w-auto"
        >
          Send Message
        </button>
      </form>
    </div>
  </div>
</section>
