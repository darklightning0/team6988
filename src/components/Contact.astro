---
import SectionHeader from './SectionHeader.astro';

const inputClass =
  'w-full rounded-xl border border-team-tertiary-800/70 bg-gradient-to-br from-team-primary-950/40 to-team-tertiary-950/50 px-4 py-3 text-team-light transition-all duration-500 ease-out placeholder:text-team-light/40 focus:border-team-secondary focus:outline-none';
---

<section class="mx-auto max-w-4xl px-4 py-24">
  <SectionHeader title="GET IN TOUCH" />

  <div class="grid gap-12 md:grid-cols-2 md:gap-16">
    <div class="space-y-10 text-team-light/80">
      <p class="text-lg leading-relaxed text-team-light/60">
        Interested in partnering with Team 6988? Reach out about sponsorships,
        mentoring opportunities, or community events. We would love to hear from
        you.
      </p>

      <div class="space-y-8">
        <div class="space-y-2">
          <div class="flex items-center gap-2">
            <svg
              class="h-4 w-4 shrink-0 text-team-secondary"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
              ></path>
            </svg>
            <p
              class="text-sm font-semibold uppercase tracking-wider text-team-secondary"
            >
              Email
            </p>
          </div>
          <a
            href="mailto:contact@frc6988.com"
            class="block pl-6 text-lg text-team-accent transition-all duration-500 ease-out hover:text-team-accent-400"
          >
            contact@frc6988.com
          </a>
        </div>

        <div class="space-y-2">
          <div class="flex items-center gap-2">
            <svg
              class="h-4 w-4 shrink-0 text-team-secondary"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
              ></path>
            </svg>
            <p
              class="text-sm font-semibold uppercase tracking-wider text-team-secondary"
            >
              Location
            </p>
          </div>
          <p class="pl-6 text-lg text-team-light/90">Your School / City, State</p>
        </div>
      </div>
    </div>

    <div
      class="rounded-2xl border border-team-tertiary-800/50 bg-team-dark/40 p-8 shadow-xl shadow-team-dark/50 backdrop-blur-sm"
    >
      <form class="space-y-6" action="#" method="post">
        <div>
          <label for="name" class="mb-2 block text-sm font-medium text-team-light/80">
            Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class={inputClass}
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="mb-2 block text-sm font-medium text-team-light/80">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class={inputClass}
            placeholder="you@example.com"
          />
        </div>

        <div>
          <label
            for="message"
            class="mb-2 block text-sm font-medium text-team-light/80"
          >
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class={`${inputClass} resize-y`}
            placeholder="How can we help?"></textarea>
        </div>

        <button
          type="submit"
          class="w-full rounded-xl bg-gradient-to-r from-team-primary to-team-accent px-6 py-3 font-bold text-team-light shadow-xl shadow-team-dark/50 transition-all duration-500 ease-out hover:-translate-y-1 hover:from-team-primary-600 hover:to-team-accent-400 sm:w-auto"
        >
          Send Message
        </button>
      </form>
    </div>
  </div>
</section>
