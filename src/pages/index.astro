---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import SponsorMarquee from '../components/SponsorMarquee.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PreviewCard from '../components/PreviewCard.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navbar />
  <Hero />
  <SponsorMarquee />

  <section class="mx-auto max-w-7xl px-4 py-24">
    <SectionHeader title="EXPLORE OUR TEAM" />

    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <PreviewCard
        title="About Us"
        description="Meet the students, mentors, and alumni driving Wildbyte forward."
        linkText="Meet the Team"
        href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/about`}
        imgSrc="/cards_1.webp"
      />
      <PreviewCard
        title="Our Robots"
        description="Explore our mechanical subsystems, Onshape CAD assemblies, and custom Bambu Lab P1S 3D printed components."
        linkText="View Specs"
        href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/robots`}
        imgSrc="/cards_2.webp"
      />
      <PreviewCard
        title="Impact & Projects"
        description="Discover our community outreach initiatives, our Impact Award journey, and our run in the Newton Division."
        linkText="See Our Impact"
        href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/projects`}
        imgSrc="/cards_3.webp"
      />
    </div>
  </section>

  <Contact />
  <Footer />
</Layout>
