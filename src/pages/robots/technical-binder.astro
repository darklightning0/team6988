---
import Layout from '../../layouts/Layout.astro';

---

<Layout>
  <link rel="stylesheet" href="https://developer.api.autodesk.com/modelderivative/v2/viewers/7.97/style.min.css" type="text/css">
  <script is:inline src="https://developer.api.autodesk.com/modelderivative/v2/viewers/7.97/viewer3D.min.js"></script>

  <style is:inline>
    :root {
      /* Single accent color control variable */
      /* Default: Bright electric blue (vibrant rgb stop of team-primary #1814BA) for superb readability and contrast */
      --accent-color-rgb: 38, 158, 135, 1/*80, 75, 228*/; 
      --accent-color: rgb(var(--accent-color-rgb));
    }

    .adsk-viewing-viewer .adsk-toolbar,
    .adsk-viewing-viewer .home-button,
    .adsk-viewing-viewer .viewcube,
    .adsk-viewing-viewer .viewcubeWrapper,
    .adsk-viewing-viewer .info-button,
    .adsk-viewing-viewer .settings-button,
    .adsk-viewing-viewer .fullscreen-button,
    .adsk-viewing-viewer .progressbg {
      display: none !important;
    }
    
    /* Hide scrollbar completely */
    .hide-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .hide-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    /* Custom glowing pulse for the V-arrows */
    @keyframes pulse-glow {
      0%, 100% { 
        opacity: 0.4; 
        filter: drop-shadow(0 0 2px rgba(var(--accent-color-rgb), 0.2)); 
      }
      50% { 
        opacity: 1; 
        filter: drop-shadow(0 0 10px rgba(var(--accent-color-rgb), 0.8)); 
      }
    }
    .animate-pulse-glow {
      animation: pulse-glow 2.5s infinite ease-in-out;
    }

    /* Smooth ease-in-out transition for sliding indicators (symmetric parabolic acceleration/deceleration) */
    .smooth-transition {
      transition: all 0.35s cubic-bezier(0.65, 0, 0.35, 1);
    }

    /* Mobile: hide desktop overlay text — replaced by bottom drawer */
    @media (max-width: 767px) {
      .text-overlay > div {
        display: none !important;
      }
    }

    /* Tablet: tighter overlay panels for more 3D viewer breathing room */
    @media (min-width: 768px) and (max-width: 1023px) {
      .text-overlay > div {
        max-width: 220px !important;
      }
      /* Move panels more towards center on iPad */
      .text-overlay > div[class*="md:left-16"] {
        left: 10vw !important;
      }
      .text-overlay > div[class*="md:right-16"] {
        right: 10vw !important;
      }
      .text-overlay > div[class*="md:top-24"] {
        top: 15dvh !important;
      }
      .text-overlay > div[class*="md:bottom-32"] {
        bottom: 18dvh !important;
      }
      .text-overlay > div h2 {
        font-size: 1.1rem !important;
      }
      .text-overlay > div p {
        font-size: 0.55rem !important;
        line-height: 1.6 !important;
      }
    }

    /* Mobile drawer card styling */
    .mobile-card {
      min-width: 180px;
      max-width: 220px;
      flex-shrink: 0;
      scroll-snap-align: start;
    }

    #drawer-chevron.rotated {
      transform: rotate(180deg);
    }

    /* Prevent dynamic mobile page scrolling and enforce exact dynamic heights */
    html, body {
      height: 100dvh !important;
      overflow: hidden !important;
    }
    .dvh-screen {
      height: 100dvh !important;
    }
    .dvh-min-screen {
      min-height: 100dvh !important;
    }
    .dvh-track {
      height: 200dvh !important;
    }
  </style>

  <main class="h-screen dvh-screen w-full overflow-hidden bg-team-dark relative font-sans">
    
    <div id="slide-track" class="w-full h-[200vh] dvh-track transform translate-y-0" style="transition: transform 1.2s cubic-bezier(0.77, 0, 0.175, 1);">
      
      <section class="h-screen dvh-screen w-full relative bg-team-dark">
        
        <div id="aps-viewer" class="absolute inset-0 z-0"></div>


        <div class="absolute top-4 md:top-8 left-1/2 transform -translate-x-1/2 z-40 w-[95%] md:w-11/12 max-w-4xl">
          <div id="subsystem-nav-container" class="relative bg-white/40 backdrop-blur-2xl border border-white/60 rounded-full p-1.5 flex justify-start md:justify-between shadow-[0_8px_30px_rgba(0,0,0,0.06)] gap-1 overflow-x-auto hide-scrollbar scroll-smooth">
            <!-- Sliding background indicator -->
            <div id="subsystem-indicator" class="absolute bg-white shadow-md rounded-full smooth-transition z-0"></div>

            <button data-target="full" class="subsystem-btn relative z-10 px-5 md:px-6 py-2 md:py-2.5 rounded-full text-team-brand-accent font-bold text-[10px] md:text-sm tracking-wide transition-all duration-300 min-w-max md:min-w-0 md:w-1/5 text-center">
              ASSEMBLY
            </button>
            <button data-target="NAUO289" class="subsystem-btn relative z-10 px-5 md:px-6 py-2 md:py-2.5 rounded-full text-gray-500 hover:text-gray-900 font-bold text-[10px] md:text-sm tracking-wide transition-all duration-300 min-w-max md:min-w-0 md:w-1/5 text-center">
              DRIVEBASE
            </button>
            <button data-target="NAUO861" class="subsystem-btn relative z-10 px-5 md:px-6 py-2 md:py-2.5 rounded-full text-gray-500 hover:text-gray-900 font-bold text-[10px] md:text-sm tracking-wide transition-all duration-300 min-w-max md:min-w-0 md:w-1/5 text-center">
              INTAKE
            </button>
            <button data-target="NAUO1171" class="subsystem-btn relative z-10 px-5 md:px-6 py-2 md:py-2.5 rounded-full text-gray-500 hover:text-gray-900 font-bold text-[10px] md:text-sm tracking-wide transition-all duration-300 min-w-max md:min-w-0 md:w-1/5 text-center">
              HOPPER
            </button>
            <button data-target="NAUO2111" class="subsystem-btn relative z-10 px-5 md:px-6 py-2 md:py-2.5 rounded-full text-gray-500 hover:text-gray-900 font-bold text-[10px] md:text-sm tracking-wide transition-all duration-300 min-w-max md:min-w-0 md:w-1/5 text-center">
              SHOOTER
            </button>
          </div>
        </div>

        <div class="absolute inset-0 z-10 pointer-events-none">
          
          <div id="overlay-full" class="text-overlay absolute inset-0 transition-all duration-500 opacity-100 visible pointer-events-none">
            <div class="absolute top-20 md:top-24 left-4 md:left-16 w-[45%] md:max-w-[280px] pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Team 6988</h3>
              <h2 class="text-2xl md:text-4xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Sparky</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Welcome to the interactive technical binder for Sparky, built for the FIRST Robotics Rebuilt season. Explore the engineering, manufacturing, and strategic design behind our machine.
              </p>
            </div>

            <div class="absolute bottom-28 md:bottom-32 left-4 md:left-16 w-[45%] md:max-w-[280px] pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Navigation</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Controls</h2>
              <p class="text-[0.6rem] md:text-xs leading-relaxed text-gray-600 font-medium mb-4">
                Orbit: Left Click + Drag<br>Pan: Right Click + Drag<br>Zoom: Scroll Wheel
              </p>
              <div class="space-y-2">
                <p class="text-[0.65rem] leading-relaxed text-gray-500 tracking-widest font-bold">
                  <span class="text-gray-900 uppercase">Isolate:</span> Hides all other parts to focus strictly on the active mechanism.
                </p>
                <p class="text-[0.65rem] leading-relaxed text-gray-500 tracking-widest font-bold">
                  <span class="text-gray-900 uppercase">Ghost:</span> Renders the rest of the chassis transparent to provide mounting context.
                </p>
              </div>
            </div>

            <div class="absolute top-20 md:top-24 right-4 md:right-16 w-[45%] md:max-w-[280px] text-right pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Architecture</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Subsystems</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Use the navigation pill to jump between subsystems. Combine these views with the Explode slider to investigate internal gearbox and mounting geometry.
              </p>
            </div>
            
            <div class="absolute bottom-28 md:bottom-32 right-4 md:right-16 w-[45%] md:max-w-[280px] text-right pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Strategy</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Rebuilt Season</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Sparky is engineered to maximize cycle times and defensive resilience. Featuring a massive 60-piece hopper capacity and dual Limelight tracking for absolute field odometry.
              </p>
            </div>
          </div>

          <div id="overlay-NAUO289" class="text-overlay absolute inset-0 transition-all duration-500 opacity-0 invisible pointer-events-none">
            <div class="absolute top-20 md:top-24 left-4 md:left-16 w-[45%] md:max-w-[300px] pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Drivetrain</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Kinematics</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Powered by 8 Kraken X60 motors, the chassis utilizes 4 SDS MK5i swerve modules (L2 gearing). These modules structurally bind the chassis corners together for maximum rigidity.
              </p>
            </div>
            <div class="absolute bottom-28 md:bottom-32 left-4 md:left-16 w-[45%] md:max-w-[300px] pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Drivetrain</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Frame</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Constructed from 25x50mm aluminum extrusions, the chassis measures a compact 69.25 x 69.25 cm to navigate crowded field environments easily.
              </p>
            </div>
            <div class="absolute top-20 md:top-24 right-4 md:right-16 w-[45%] md:max-w-[300px] text-right pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Drivetrain</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Belly Pan</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                The mounting plate is strategically pocketed to minimize weight while maintaining structural integrity. It serves as a reinforced mounting bed for centralized electrical routing.
              </p>
            </div>
            <div class="absolute bottom-28 md:bottom-32 right-4 md:right-16 w-[45%] md:max-w-[300px] text-right pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Drivetrain</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Bumpers</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Wood-backed, reversible red-blue bumpers are structurally integrated into the plate. They provide critical impact protection for the hopper panels while guiding the intake's deployment.
              </p>
            </div>
          </div>

          <div id="overlay-NAUO861" class="text-overlay absolute inset-0 transition-all duration-500 opacity-0 invisible pointer-events-none">
            <div class="absolute top-20 md:top-24 left-4 md:left-16 w-[45%] md:max-w-[300px] pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Intake</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Actuation</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Powered by a Kraken X60 with a 9.18:1 reduction, the arm maintains precise positioning. A custom 3D-printed mechanical hard-stop protects the assembly from over-extension impacts.
              </p>
            </div>
            <div class="absolute bottom-28 md:bottom-32 left-4 md:left-16 w-[45%] md:max-w-[300px] pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Intake</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Control</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Software-driven closed-loop control utilizes absolute encoders to automatically snap and hold the intake at optimal deployment and stowage angles.
              </p>
            </div>
            <div class="absolute top-20 md:top-24 right-4 md:right-16 w-[45%] md:max-w-[300px] text-right pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Intake</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Acquisition</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                A grip-tape-enhanced Delrin roller acts as the primary acquisition mechanism. Secondary compliant wheels accelerate cycle times and prevent game piece jamming during intake.
              </p>
            </div>
            <div class="absolute bottom-28 md:bottom-32 right-4 md:right-16 w-[45%] md:max-w-[300px] text-right pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Intake</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Durability</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                A rugged 25x50mm extrusion spans the front roller to absorb field collisions. Extended side panels integrate directly with the intake to expand the robot's capacity to ~16 game pieces.
              </p>
            </div>
          </div>

          <div id="overlay-NAUO1171" class="text-overlay absolute inset-0 transition-all duration-500 opacity-0 invisible pointer-events-none">
            <div class="absolute top-20 md:top-24 left-4 md:left-16 w-[45%] md:max-w-[300px] pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Hopper</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Floor Belts</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Ten 565mm timing belts create an active floor across the entire hopper, eliminating dead zones, preventing jams, and aggressively driving game pieces toward the indexer.
              </p>
            </div>
            <div class="absolute bottom-28 md:bottom-32 left-4 md:left-16 w-[45%] md:max-w-[300px] pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Hopper</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Funneling</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Four 3D-printed directional panels aggressively funnel game pieces toward the shooter mechanism, stylized with the signature 6988 panther eye aesthetic.
              </p>
            </div>
            <div class="absolute top-20 md:top-24 right-4 md:right-16 w-[45%] md:max-w-[300px] text-right pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Hopper</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Capacity</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Manufactured from resilient impact-resistant polycarbonate, the side panels maximize internal volume, allowing the machine to hold a massive payload of over 60 game pieces.
              </p>
            </div>
            <div class="absolute bottom-28 md:bottom-32 right-4 md:right-16 w-[45%] md:max-w-[300px] text-right pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Hopper</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Odometry</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Twin Limelight 4 vision systems are mounted to the side panels in custom 3D-printed angled housings, utilizing AprilTag pipelines to maintain flawless absolute field odometry.
              </p>
            </div>
          </div>

          <div id="overlay-NAUO2111" class="text-overlay absolute inset-0 transition-all duration-500 opacity-0 invisible pointer-events-none">
            <div class="absolute top-20 md:top-24 left-4 md:left-16 w-[45%] md:max-w-[300px] pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Shooter</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Flywheels</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Powered by dual PID-tuned Falcon 500s geared up 3.25:1, the shooter utilizes ten 4-inch wheels split across two main flywheels for unmatched shot stability and precision.
              </p>
            </div>
            <div class="absolute bottom-28 md:bottom-32 left-4 md:left-16 w-[45%] md:max-w-[300px] pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Shooter</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Targeting</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Two dedicated Limelight 4s lock onto the hub, allowing the software to automatically align the drivetrain and calculate dynamic RPMs for on-the-fly shooting from anywhere in the zone.
              </p>
            </div>
            <div class="absolute top-20 md:top-24 right-4 md:right-16 w-[45%] md:max-w-[300px] text-right pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Shooter</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Agitator</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                An active agitator mechanism sits at the throat of the shooter, aggressively breaking up jams and ensuring a smooth, continuous feed of game pieces into the flywheels.
              </p>
            </div>
            <div class="absolute bottom-28 md:bottom-32 right-4 md:right-16 w-[45%] md:max-w-[300px] text-right pointer-events-none md:pointer-events-auto">
              <h3 class="text-[0.5rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-team-brand-accent uppercase mb-1">Shooter</h3>
              <h2 class="text-lg md:text-2xl font-black tracking-tighter text-gray-900 mb-2 uppercase italic">Trajectory</h2>
              <p class="text-[0.6rem] md:text-[0.6rem] md:text-xs leading-relaxed md:leading-loose text-gray-600 font-medium">
                Clear polycarbonate guide plates ensure a rigid, stable trajectory for exiting game pieces, reinforced by twin 5mm aluminum side plates bearing the organic panther visual identity.
              </p>
            </div>
          </div>

        </div>

        <!-- Mobile Info Drawer (replaces corner overlays on phones) -->
        <div id="mobile-drawer" class="md:hidden absolute bottom-[68px] left-0 right-0 z-30 px-3">
          <div class="bg-white/40 backdrop-blur-2xl border border-white/60 rounded-2xl overflow-hidden shadow-[0_8px_30px_rgba(0,0,0,0.06)]">
            <button id="drawer-toggle" class="w-full flex items-center justify-between px-4 py-2">
              <span id="drawer-label" class="text-[10px] font-bold tracking-[0.15em] text-gray-900 uppercase">Assembly Details</span>
              <svg id="drawer-chevron" class="w-3.5 h-3.5 text-gray-500 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"></path>
              </svg>
            </button>
            <div id="drawer-content" class="overflow-hidden" style="max-height: 0; transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);">
              <div id="mobile-cards" class="flex gap-2.5 px-3 pb-3 overflow-x-auto hide-scrollbar snap-x snap-mandatory">
              </div>
            </div>
          </div>
        </div>

        <div class="absolute bottom-4 md:bottom-8 left-1/2 transform -translate-x-1/2 z-40 w-[95%] md:w-max max-w-4xl">
          <div class="bg-white/40 backdrop-blur-2xl border border-white/60 rounded-[2rem] p-2 md:p-3 px-3 md:px-8 flex flex-row items-center justify-between gap-2 md:gap-10 shadow-[0_8px_30px_rgba(0,0,0,0.06)]">
            
            <div id="mode-nav-container" class="relative flex bg-gray-100/50 rounded-xl p-1 border border-gray-200/50">
              <!-- Sliding background indicator -->
              <div id="mode-indicator" class="absolute bg-white shadow-sm rounded-lg smooth-transition z-0"></div>

              <button id="isolate-btn" class="mode-toggle relative z-10 px-3 md:px-5 py-1.5 md:py-2 rounded-lg text-team-brand-accent font-bold text-[9px] md:text-xs uppercase tracking-wider transition-colors">
