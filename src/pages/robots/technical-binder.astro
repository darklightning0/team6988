          'NAUO861': 'Intake',
          'NAUO1171': 'Hopper',
          'NAUO2111': 'Shooter'
        };
        if (drawerLabel) {
          drawerLabel.textContent = (labelMap[target] || 'Subsystem') + ' Details';
        }

        const panels = overlay.querySelectorAll(':scope > div');
        panels.forEach(panel => {
          const card = document.createElement('div');
          card.className = 'mobile-card bg-white/70 backdrop-blur-xl rounded-xl p-3 border border-white/40 shadow-sm';

          const h3 = panel.querySelector('h3');
          const h2 = panel.querySelector('h2');
          const p = panel.querySelector('p');
          const details = panel.querySelector('.space-y-2');

          let html = '';
          if (h3) html += '<h3 class="text-[8px] font-bold tracking-[0.2em] uppercase mb-0.5" style="color: var(--accent-color);">' + h3.textContent + '</h3>';
          if (h2) html += '<h2 class="text-xs font-black tracking-tight text-gray-900 uppercase italic mb-1">' + h2.textContent + '</h2>';
          if (p) html += '<p class="text-[9px] leading-relaxed text-gray-600 font-medium">' + p.innerHTML + '</p>';
          if (details) {
            html += '<div class="mt-1.5 space-y-1">';
            details.querySelectorAll('p').forEach(dp => {
              html += '<p class="text-[9px] leading-relaxed text-gray-500 font-bold">' + dp.innerHTML + '</p>';
            });
            html += '</div>';
          }

          card.innerHTML = html;
          mobileCards.appendChild(card);
        });

        if (drawerOpen && drawerContent) {
          requestAnimationFrame(() => {
            drawerContent.style.maxHeight = drawerContent.scrollHeight + 'px';
          });
        }
      }

      // Populate initial content for mobile drawer
      populateMobileCards('full');
    }
  </script>
</Layout>