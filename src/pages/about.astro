---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import SectionHeader from '../components/SectionHeader.astro';

const subteams = [
  {
    name: 'Mechanical & CAD',
    description: 'Specializes in design, CAD modeling on Onshape, CNC routing, and robust hardware fabrication. Responsible for our robust SDS MK5i swerve drivetrain and dynamic hopper mechanisms.',
    icon: 'M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82zM12 20l7-7-8.59-8.59L3 12v7h7v1z',
    glow: 'rgba(38,158,135,0.4)',
  },
  {
    name: 'Software & Vision',
    description: 'Programs our autonomous pathways, vision pipelines, closed-loop PID control loops, and scouting systems. Powered by WPILib, Limelight vision tag-tracking, and absolute field odometry.',
    icon: 'M8 16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H2a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h6zm12-6a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2h-6a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h6z',
    glow: 'rgba(24,20,186,0.4)',
  },
  {
    name: 'Electronics & Control',
    description: 'Handles the electrical backbone of the machine. Routes power distribution panels (PDP), custom sensor arrays, high-speed Ethernet routing, and Pneumatic hub integrations.',
    icon: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
    glow: 'rgba(245,158,11,0.4)',
  },
  {
    name: 'Outreach & Strategy',
    description: 'Spreads FIRST culture in the local community through STEM camps, workshops, school visits, and fundraising. Handles our award submissions and FRC Impact Award presentation.',
    icon: 'M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z',
    glow: 'rgba(38,158,135,0.4)',
  },
];

const milestones = [
  {
    year: '2026',
    title: 'Rebuilt Season Dominance',
    description: 'Unveiled Sparky, featuring Onshape assemblies, active 60-piece belt hoppers, vision tracking, and custom Bambu Lab P1S carbon fiber nylon printed parts.',
  },
  {
    year: '2025',
    title: 'Newton Division Finalists',
    description: 'Travelled to the FIRST Championship, making a deep playoff run in the highly competitive Newton Division. Awarded the Autonomous Award.',
  },
  {
    year: '2024',
    title: 'Regional Championship & Growth',
    description: 'Won our first major Regional Event, setting new team high-score cycles and establishing ourselves as a regional powerhouse in software.',
  },
  {
    year: '2023',
    title: 'Outreach & Rookie Beginnings',
    description: 'Founded with the mission to bring world-class competitive robotics to our community. Launched multiple FLL teams and STEM camps.',
  },
];

const mentors = [
  { name: 'Dr. Sarah Carter', role: 'Lead Engineering Mentor // Mechanical Specialist' },
  { name: 'Alex Rivers', role: 'Lead Software Mentor // Systems Engineer' },
  { name: 'Marcus Chen', role: 'Electronics Mentor // Hardware Designer' },
  { name: 'Elena Rostova', role: 'Strategy & Impact Lead Mentor' },
];
---

<Layout>
  <Navbar />

  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 overflow-hidden bg-team-dark">
    <!-- Deep grid & overlay -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.01)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.01)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,#000_40%,transparent_100%)] pointer-events-none" aria-hidden="true"></div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-team-secondary/10 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-4 text-center">
      <span class="text-[9px] md:text-[10px] font-black tracking-[0.4em] text-team-secondary uppercase">
        TEAM BIOGRAPHY // FRC 6988
      </span>
      <h1 class="mt-4 text-4xl font-black tracking-tighter text-team-light md:text-7xl uppercase italic">
        ABOUT WILDBYTE
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-xs md:text-sm leading-relaxed text-team-light/65 uppercase tracking-wider">
        Where engineering precision meets predatory instinct. Wildbyte is a competitive FIRST Robotics team comprised of passionate high school students, dedicated professional mentors, and supportive community sponsors.
      </p>
    </div>
  </section>

  <!-- Mission Statement -->
  <section class="relative mx-auto max-w-4xl px-4 pb-20">
    <div class="relative rounded-3xl border border-white/10 bg-white/5 p-8 md:p-12 shadow-[0_12px_40px_rgba(0,0,0,0.3)] backdrop-blur-2xl text-center overflow-hidden">
      <!-- Glow effect inside -->
      <div class="absolute -top-12 -left-12 w-24 h-24 bg-team-secondary/20 rounded-full blur-xl pointer-events-none"></div>
      
      <h2 class="text-xs font-black tracking-[0.25em] text-team-secondary uppercase mb-4">
        OUR VISION & CORE MISSION
      </h2>
      <p class="text-sm md:text-lg leading-relaxed text-team-light font-bold italic">
        "To inspire, educate, and empower the next generation of STEM leaders by fostering a collaborative culture of hard work, engineering rigor, and community engagement. At Wildbyte, we don't just build competitive robots; we build leaders, innovators, and problem solvers."
      </p>
    </div>
  </section>

  <!-- Subteam Blueprint -->
  <section class="relative mx-auto max-w-7xl px-4 py-20 border-t border-white/5">
    <SectionHeader title="THE SUBTEAM BLUEPRINTS" />
    
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4 mt-12">
      {subteams.map((team) => (
        <div 
          class="relative group rounded-2xl border border-white/5 bg-white/5 p-6 backdrop-blur-md smooth-transition hover:-translate-y-2 hover:border-team-secondary/50 hover:bg-white/10 flex flex-col justify-between"
          style={`box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);`}
        >
          <!-- Neon hover glow -->
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 smooth-transition pointer-events-none" style={`box-shadow: 0 0 30px ${team.glow};`}></div>
          
          <div class="space-y-4 relative z-10">
            <!-- Icon -->
            <div class="h-10 w-10 rounded-xl border border-white/10 bg-white/5 flex items-center justify-center text-team-secondary smooth-transition group-hover:scale-110">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                <path d={team.icon}></path>
              </svg>
            </div>
            
            <h3 class="text-sm md:text-base font-black tracking-tight text-team-light uppercase italic">
              {team.name}
            </h3>
            <p class="text-[11px] leading-relaxed text-team-light/60">
              {team.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Timeline / Milestones -->
  <section class="relative mx-auto max-w-5xl px-4 py-20 border-t border-white/5">
    <SectionHeader title="MILESTONES & CHRONOLOGY" />

    <div class="relative mt-16 max-w-3xl mx-auto">
      <!-- Vertical line down center -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-team-secondary via-team-primary to-transparent -translate-x-1/2"></div>

      <div class="space-y-12">
        {milestones.map((milestone, idx) => (
          <div class={`relative flex flex-col md:flex-row items-start md:items-center ${idx % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
            
            <!-- Bullet Point node -->
            <div class="absolute left-4 md:left-1/2 h-4.5 w-4.5 rounded-full border-2 border-team-secondary bg-team-dark z-20 -translate-x-1/2 smooth-transition hover:scale-125 hover:bg-team-secondary shadow-[0_0_10px_rgba(38,158,135,0.8)]"></div>

            <!-- Content Card -->
            <div class={`w-full md:w-[45%] pl-10 md:pl-0 ${idx % 2 === 0 ? 'md:pr-10 text-left md:text-right' : 'md:pl-10 text-left'}`}>
              <div class="rounded-2xl border border-white/5 bg-white/5 p-6 backdrop-blur-md smooth-transition hover:border-team-secondary/30">
                <span class="text-xs font-black tracking-widest text-team-secondary">{milestone.year}</span>
                <h3 class="text-sm md:text-base font-black tracking-tight text-team-light uppercase italic mt-1">{milestone.title}</h3>
                <p class="text-[11px] leading-relaxed text-team-light/60 mt-2">{milestone.description}</p>
              </div>
            </div>

            <!-- Spacer for layout alignment on desktop -->
            <div class="hidden md:block w-[45%]"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mentors & Leadership -->
  <section class="relative mx-auto max-w-5xl px-4 py-20 border-t border-white/5">
    <SectionHeader title="MENTORS & LEADERS" />

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-4 mt-12">
      {mentors.map((mentor) => (
        <div class="rounded-2xl border border-white/5 bg-white/5 p-5 text-center backdrop-blur-md smooth-transition hover:border-team-secondary/40 hover:bg-white/10">
          <div class="mx-auto mb-4 h-12 w-12 rounded-full border border-white/10 bg-white/5 flex items-center justify-center text-team-secondary">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="text-xs md:text-sm font-black tracking-tight text-team-light uppercase italic">
            {mentor.name}
          </h3>
          <p class="text-[9px] font-bold tracking-widest text-team-light/40 uppercase mt-1">
            {mentor.role}
          </p>
        </div>
      ))}
    </div>
  </section>

  <Contact />
  <Footer />
</Layout>
